# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY # NEVER expose to frontend

# ─── Resend (Email) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=YOUR_RESEND_API_KEY
FROM_EMAIL=YOUR_VERIFIED_EMAIL         # Must be a verified domain in Resend
ADMIN_EMAIL=YOUR_ADMIN_EMAIL      # Admin notification recipient

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
